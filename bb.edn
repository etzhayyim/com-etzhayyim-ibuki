                                      ibuki.methods.test-digest
                                      ibuki.methods.test-datoms
                                      ibuki.methods.test-metabolism
                                      ibuki.methods.test-kotoba-bridge
                                      ibuki.methods.test-quorum
                                      ibuki.methods.test-infer
                                      ibuki.methods.test-member-submit

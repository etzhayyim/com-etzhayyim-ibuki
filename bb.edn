                           "methods/test_sick_colony.cljc"
                           "methods/test_digest.cljc"
                           "methods/test_datoms.cljc"
                           "methods/test_metabolism.cljc"
                           "methods/test_kotoba_bridge.cljc"
                           "methods/test_quorum.cljc"
                           "methods/test_infer.cljc"
                           "methods/test_member_submit.cljc"
                           "methods/test_symbiosis.cljc"
                           "methods/test_kaizen_feedback.cljc"
                           "methods/test_autorun.cljc"
